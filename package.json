{
  "name": "tfg-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run tests/Unit",
    "test:integration": "vitest run tests/Integration",
    "test:e2e": "playwright test",
    "model:export": "python3 ./scripts/model/export-onnx.py",
    "data:download": "node ./scripts/data/download-sources.mjs",
    "data:build": "node ./scripts/data/build-database.mjs",
    "data:prepare": "npm run data:download && npm run data:build"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^7.0.2",
    "@capacitor/android": "^7.6.1",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/clipboard": "^7.0.4",
    "@capacitor/core": "^7.6.1",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/ios": "^7.6.1",
    "@ionic/pwa-elements": "^3.4.0",
    "@ionic/react": "^8.8.4",
    "@ionic/react-router": "^8.8.4",
    "fast-xml-parser": "^5.6.0",
    "ionicons": "^8.0.13",
    "onnxruntime-web": "^1.24.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^5.3.4",
    "sql.js": "^1.14.1",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.1",
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "polished": "^4.3.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
